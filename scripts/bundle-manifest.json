{
	"bundleName": "v-claw-core-bundle",
	"bundleVersion": "1.0.3",
	"platform": "win-x64",
	"bundleRepo": "https://github.com/cong91/v-claw-bundle",
	"releaseTag": "v1.0.3",
	"releaseAssetUrlPattern": "https://github.com/cong91/v-claw-bundle/releases/download/{tag}/{file}",
	"artifactNaming": {
		"core": "v-claw-core-bundle-{version}-{platform}.zip"
	},
	"manifestName": "v-claw-core-manifest.json",
	"dependencies": {
		"openclaw": "2026.4.29"
	},
	"requiredPaths": [
		"package.json",
		"node_modules/openclaw/openclaw.mjs",
		".openclaw/plugin-runtime-deps",
		"node_modules/openclaw/dist/extensions/zalo/package.json"
	],
	"stagePackage": {
		"name": "v-claw-core-bundle",
		"private": true,
		"description": "Canonical V-Claw core bundle payload"
	}
}
